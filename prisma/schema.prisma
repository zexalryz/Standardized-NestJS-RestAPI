generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InviteCode {
  code      String   @id
  used      Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())
  usedAt    DateTime?
}

# ─── Server ────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Database ──────────────────────────────────────
# SQLite (default): file:./dev.db
# PostgreSQL:      postgresql://user:pass@localhost:5432/auth_api
# MySQL:           mysql://user:pass@localhost:3306/auth_api
DATABASE_URL=file:./dev.db

# ─── Auth ──────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m

# ─── Rate limiting ─────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ─── Public URL (optional) ─────────────────────────
# Set when deploying behind a public HTTPS proxy
# Used by Swagger and HSTS configuration
# PUBLIC_URL=https://api.example.com
